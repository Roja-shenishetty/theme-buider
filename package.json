{
  "name": "my-app",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "@tailwindcss/oxide-win32-x64-msvc": "^4.2.2",
    "prettier": "^3.7.4",
    "turbo": "^2.9.5",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "@types/react": "19.2.4",
    "@types/react-dom": "19.2.3"
  },
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0"
    },
    "packageExtensions": {
      "react-native@*": {
        "dependencies": {
          "react": "19.1.0"
        }
      },
      "expo@*": {
        "dependencies": {
          "react": "19.1.0"
        }
      },
      "@react-navigation/*": {
        "dependencies": {
          "react": "19.1.0"
        }
      }
    }
  }
}